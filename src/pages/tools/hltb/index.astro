---
import ToolLayout from '../../../layouts/ToolLayout.astro';
---
<ToolLayout
  title="гғӘгӮўгғ«гӮҝгӮӨгғ гғ—гғ¬гӮӨгғӨгғјзөұиЁҲ | гғҮгғғгӮӯж§ӢзҜүГ—гғӯгғјгӮ°гғ©гӮӨгӮҜ"
  description="гғҮгғғгӮӯж§ӢзҜүГ—гғӯгғјгӮ°гғ©гӮӨгӮҜгӮІгғјгғ гҒ®еҗҢжҷӮжҺҘз¶ҡгғ—гғ¬гӮӨгғӨгғјж•°гӮ’гғӘгӮўгғ«гӮҝгӮӨгғ иЎЁзӨәгҖӮSteamе…¬ејҸAPIгғҷгғјгӮ№гҖӮ"
  canonical="https://www.randaworks.com/tools/hltb/"
  pageType="hltb"
  source="hltb"
  tag="гғ©гӮӨгғ–гғҮгғјгӮҝ"
  heading="гғӘгӮўгғ«гӮҝгӮӨгғ гғ—гғ¬гӮӨгғӨгғјзөұиЁҲ"
  desc="гғҮгғғгӮӯж§ӢзҜүГ—гғӯгғјгӮ°гғ©гӮӨгӮҜгҒ®еҗҢжҷӮжҺҘз¶ҡгғ—гғ¬гӮӨгғӨгғјж•°гҒЁгғ¬гғ“гғҘгғји©•дҫЎгӮ’гғӘгӮўгғ«гӮҝгӮӨгғ иЎЁзӨәгҖӮ"
  breadcrumbs={[{ href: '/history-tools/', label: 'гғ„гғјгғ«йӣҶ' }, { label: 'гғ—гғ¬гӮӨгғӨгғјзөұиЁҲ' }]}
  excludeTools={['hltb']}
  gamePitch="ж—Ҙжң¬еҸІеӣ жһңгӮҜгғӯгғӢгӮҜгғ«гӮӮеҗҢгӮёгғЈгғігғ«гҒ®гғҮгғғгӮӯж§ӢзҜүгғӯгғјгӮ°гғ©гӮӨгӮҜгҖӮгғ—гғ¬гӮӨгғӨгғјзөұиЁҲгӮ’жҜ”ијғгҒ—гҒҰгҒҝгҒҰгҒҸгҒ гҒ•гҒ„гҖӮ"
  steamContext="жҜ”ијғиЎЁгҒ«жҺІијүдёӯгҒ®гғҮгғғгӮӯж§ӢзҜүгғӯгғјгӮ°гғ©гӮӨгӮҜ"
>
  <div class="tool-workspace" id="hltb-tool">
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:0.88rem;font-family:'Space Grotesk','Noto Sans JP',sans-serif;" id="hltbTable">
        <thead>
          <tr style="border-bottom:1px solid rgba(255,255,255,0.1);">
            <th style="text-align:center;padding:10px 8px;color:var(--tool-accent);font-size:0.72rem;letter-spacing:0.06em;text-transform:uppercase;font-weight:600;width:40px;">#</th>
            <th style="text-align:left;padding:10px 8px;color:var(--tool-accent);font-size:0.72rem;letter-spacing:0.06em;text-transform:uppercase;font-weight:600;">гӮІгғјгғ еҗҚ</th>
            <th style="text-align:right;padding:10px 8px;color:var(--tool-accent);font-size:0.72rem;letter-spacing:0.06em;text-transform:uppercase;font-weight:600;cursor:pointer;" data-sort="ccu">еҗҢжҺҘгғ—гғ¬гӮӨгғӨгғј в–ј</th>
            <th style="text-align:right;padding:10px 8px;color:var(--tool-accent);font-size:0.72rem;letter-spacing:0.06em;text-transform:uppercase;font-weight:600;cursor:pointer;" data-sort="positiveRate">еҘҪи©•зҺҮ</th>
            <th style="text-align:left;padding:10px 8px;color:var(--tool-accent);font-size:0.72rem;letter-spacing:0.06em;text-transform:uppercase;font-weight:600;">и©•дҫЎ</th>
            <th style="text-align:center;padding:10px 8px;color:var(--tool-accent);font-size:0.72rem;letter-spacing:0.06em;text-transform:uppercase;font-weight:600;">Steam</th>
          </tr>
        </thead>
        <tbody id="hltbBody">
          <tr><td colspan="6" style="padding:24px;text-align:center;color:var(--text-muted);">гғҮгғјгӮҝеҸ–еҫ—дёӯвҖҰ</td></tr>
        </tbody>
      </table>
    </div>
    <div class="tool-output" style="margin-top:16px;">
      <span class="tool-output-label">гғҮгғјгӮҝгҒ«гҒӨгҒ„гҒҰ</span>
      <p style="margin:0;color:var(--text-muted);font-size:0.82rem;">Steamе…¬ејҸAPIгҒӢгӮүеҗҢжҷӮжҺҘз¶ҡж•°гӮ’гғӘгӮўгғ«гӮҝгӮӨгғ еҸ–еҫ—гҖӮгғҮгғјгӮҝгҒҜж•°еҲҶгҒ”гҒЁгҒ«жӣҙж–°гҒ•гӮҢгҒҫгҒҷгҖӮ<span id="fetchTime" style="margin-left:8px;"></span></p>
    </div>
  </div>

  <script is:inline>
  (function () {
    var GAMES = [
      { appid: '646570', name: 'Slay the Spire' },
      { appid: '1892930', name: 'Slay the Spire 2' },
      { appid: '2379780', name: 'Balatro' },
      { appid: '1145360', name: 'Hades' },
      { appid: '1145350', name: 'Hades II' },
      { appid: '1092790', name: 'Inscryption' },
      { appid: '1102190', name: 'Monster Train' },
      { appid: '601840', name: 'Griftlands' },
      { appid: '998740', name: 'Ring of Pain' },
      { appid: '1076200', name: 'Roguebook' },
      { appid: '1385380', name: 'Across the Obelisk' },
      { appid: '1188930', name: 'Chrono Ark' },
      { appid: '1135810', name: 'Vault of the Void' }
    ];
    var FEATURED = { appid: '4403470', name: 'ж—Ҙжң¬еҸІеӣ жһңгӮҜгғӯгғӢгӮҜгғ«' };
    var REVIEW_JA = {
      'Overwhelmingly Positive': 'ең§еҖ’зҡ„гҒ«еҘҪи©•',
      'Very Positive': 'йқһеёёгҒ«еҘҪи©•',
      'Positive': 'еҘҪи©•',
      'Mostly Positive': 'гӮ„гӮ„еҘҪи©•',
      'Mixed': 'иіӣеҗҰдёЎи«–',
      'Mostly Negative': 'гӮ„гӮ„дёҚи©•',
      'Negative': 'дёҚи©•'
    };
    var sort = { key: 'ccu', desc: true };
    var cache = null;

    function $(id) { return document.getElementById(id); }
    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function rColor(p) { return p >= 95 ? '#60b568' : p >= 90 ? '#8bc34a' : p >= 80 ? '#c7a666' : p > 0 ? '#e06666' : 'var(--text-muted)'; }

    function render() {
      if (!cache) return;
      var tbody = $('hltbBody');
      tbody.innerHTML = '';
      var list = cache.slice().sort(function (a, b) {
        var va = a[sort.key] || 0, vb = b[sort.key] || 0;
        return sort.desc ? vb - va : va - vb;
      });
      for (var i = 0; i < list.length; i++) {
        var g = list[i];
        var tr = document.createElement('tr');
        tr.style.borderBottom = '1px solid rgba(255,255,255,0.04)';
        tr.innerHTML =
          '<td style="padding:8px;text-align:center;color:var(--text-muted);">' + (i + 1) + '</td>' +
          '<td style="padding:8px;">' + esc(g.name) + '</td>' +
          '<td style="text-align:right;padding:8px;font-weight:600;color:' + (g.ccu > 1000 ? '#60b568' : g.ccu > 100 ? '#8bc34a' : 'var(--text-muted)') + ';">' + (g.ccu > 0 ? g.ccu.toLocaleString() : 'вҖ”') + '</td>' +
          '<td style="text-align:right;padding:8px;color:' + rColor(g.positiveRate) + ';">' + (g.positiveRate > 0 ? g.positiveRate + '%' : 'вҖ”') + '</td>' +
          '<td style="padding:8px;color:var(--text-muted);font-size:0.82rem;">' + esc(REVIEW_JA[g.reviewDesc] || g.reviewDesc || 'вҖ”') + '</td>' +
          '<td style="text-align:center;padding:8px;"><a href="https://store.steampowered.com/app/' + esc(g.appid) + '/" target="_blank" rel="noopener noreferrer">Steam</a></td>';
        tbody.appendChild(tr);
      }
      var ftr = document.createElement('tr');
      ftr.style.borderBottom = '1px solid rgba(255,255,255,0.04)';
      ftr.style.background = 'rgba(163,184,108,0.06)';
      ftr.innerHTML =
        '<td style="padding:8px;text-align:center;">вҖ”</td>' +
        '<td style="padding:8px;color:var(--tool-accent);font-weight:600;">' + esc(FEATURED.name) + '</td>' +
        '<td colspan="3" style="padding:8px;color:var(--text-muted);text-align:center;">вҖ” й–Ӣзҷәдёӯ вҖ”</td>' +
        '<td style="text-align:center;padding:8px;"><a href="https://store.steampowered.com/app/' + FEATURED.appid + '/" target="_blank" rel="noopener noreferrer" data-track-event="steam_click" data-track-placement="hltb_featured">Steam</a></td>';
      tbody.appendChild(ftr);
      updateHeaders();
    }

    function updateHeaders() {
      var ths = document.querySelectorAll('#hltbTable th[data-sort]');
      for (var i = 0; i < ths.length; i++) {
        var th = ths[i];
        var label = th.getAttribute('data-label') || th.textContent.replace(/[\sв–Ів–ј]+$/g, '').trim();
        th.setAttribute('data-label', label);
        th.textContent = th.getAttribute('data-sort') === sort.key ? label + (sort.desc ? ' в–ј' : ' в–І') : label;
      }
    }

    async function init() {
      var ths = document.querySelectorAll('#hltbTable th[data-sort]');
      for (var i = 0; i < ths.length; i++) {
        (function (th) {
          th.addEventListener('click', function () {
            var key = th.getAttribute('data-sort');
            if (sort.key === key) { sort.desc = !sort.desc; } else { sort.key = key; sort.desc = true; }
            render();
          });
        })(ths[i]);
      }
      try {
        var appids = [];
        for (var j = 0; j < GAMES.length; j++) appids.push(GAMES[j].appid);
        var r = await fetch('/api/steam/stats/?appids=' + appids.join(','));
        var d = await r.json();
        if (d.error) throw new Error(d.error);
        cache = [];
        for (var k = 0; k < GAMES.length; k++) {
          var g = d.games[GAMES[k].appid];
          if (g) { g.appid = GAMES[k].appid; g.name = GAMES[k].name; cache.push(g); }
        }
        render();
        if (d.fetchedAt) $('fetchTime').textContent = 'еҸ–еҫ—: ' + new Date(d.fetchedAt).toLocaleString('ja-JP');
      } catch (e) {
        $('hltbBody').innerHTML = '<tr><td colspan="6" style="padding:24px;text-align:center;color:#e06666;">гғҮгғјгӮҝгӮ’еҸ–еҫ—гҒ§гҒҚгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮ<a href="javascript:location.reload()" style="color:var(--tool-accent);margin-left:8px;">еҶҚиӘӯгҒҝиҫјгҒҝ</a></td></tr>';
      }
    }

    document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init, { once: true }) : init();
  })();
  </script>
</ToolLayout>
