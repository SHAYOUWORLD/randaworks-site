---
import ToolLayout from '../../../layouts/ToolLayout.astro';
---
<ToolLayout
  title="世界史×日本史クロスクイズ | 英語の歴史トリビアに挑戦"
  description="Open Trivia DBの世界史クイズに日本史の出来事を組み合わせたクロスクイズ。英語圏の歴史トリビアと日本史を同時に学べます。"
  canonical="https://www.randaworks.com/tools/trivia/"
  pageType="trivia"
  source="trivia"
  tag="日英クロス出題"
  heading="世界史×日本史クロスクイズ"
  desc="英語圏の歴史トリビアに日本史を組み合わせた4択クイズ。"
  breadcrumbs={[
    { href: '/history-tools/', label: 'ツール集' },
    { label: '世界史×日本史クロスクイズ' },
  ]}
  excludeTools={['trivia']}
  gamePitch="世界史と日本史の同時代比較は、ゲーム内のカード連鎖でも重要な視点です。"
  steamContext="日本史因果クロニクル — 因果関係で歴史を体験するカードゲーム"
>
  <div class="tool-workspace" id="trivia-tool">
    <div class="tool-input-row">
      <label for="triviaDifficulty">難易度
        <select id="triviaDifficulty">
          <option value="easy">Easy</option>
          <option value="medium" selected>Medium</option>
          <option value="hard">Hard</option>
        </select>
      </label>
      <button class="tool-btn" id="triviaNewBtn" type="button">新しい問題</button>
    </div>
    <div class="tool-output" id="triviaQuestion"></div>
    <div class="quiz-option-grid" id="triviaChoices"></div>
    <div class="tool-output" id="triviaExplanation"></div>
  </div>

  <script is:inline>
  (function () {
    var state = { correct: '', question: '' };

    function $(id) { return document.getElementById(id); }
    function escapeHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function decodeHtml(s) { var t = document.createElement('textarea'); t.innerHTML = s; return t.value; }
    function isLocalHost(){return /^(dev\.randa|localhost|127\.0\.0\.1)$/i.test(window.location.hostname);}
    function apiBase(){return isLocalHost()?'http://127.0.0.1:8787':window.location.origin;}
    function apiUrl(path, params){
      var url = new URL(path, apiBase());
      if(params){Object.keys(params).forEach(function(key){if(params[key])url.searchParams.set(key, params[key]);});}
      return url.toString();
    }

    function track(name, payload) {
      if (window.RandaAnalytics && typeof window.RandaAnalytics.track === 'function') window.RandaAnalytics.track(name, payload || {});
      if (typeof gtag === 'function') gtag('event', name, payload || {});
    }

    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = a[i]; a[i] = a[j]; a[j] = t;
      }
      return a;
    }

    function fetchQuestion(options) {
      var shouldTrack = !options || options.track !== false;
      var btn = $('triviaNewBtn');
      var diff = $('triviaDifficulty').value;
      btn.disabled = true;
      btn.textContent = '取得中…';
      $('triviaQuestion').innerHTML = '<span class="tool-output-label">問題を取得しています…</span>';
      $('triviaChoices').innerHTML = '';
      $('triviaExplanation').innerHTML = '';

      fetch(apiUrl('/api/trivia/', { difficulty: diff }), { headers: { 'Accept': 'application/json' } })
        .then(function (r) { if (!r.ok) throw new Error('fetch failed'); return r.json(); })
        .then(function (data) {
          if (!data.results || !data.results.length) throw new Error('no data');
          var q = data.results[0];
          state.correct = decodeHtml(q.correct_answer);
          state.question = decodeHtml(q.question);
          var choices = shuffle(q.incorrect_answers.map(decodeHtml).concat([state.correct]));

          $('triviaQuestion').innerHTML =
            '<span class="tool-output-label">History / ' + escapeHtml(q.difficulty) + '</span>' +
            '<h3>' + escapeHtml(state.question) + '</h3>';

          var container = $('triviaChoices');
          container.innerHTML = '';
          choices.forEach(function (c) {
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'quiz-option';
            b.textContent = c;
            b.setAttribute('data-choice', c);
            container.appendChild(b);
          });

          $('triviaExplanation').innerHTML = '<span class="tool-output-label">回答すると正解と解説を表示します。</span>';
          if (shouldTrack) {
            track('trivia_question', { difficulty: diff });
          }
        })
        .catch(function () {
          $('triviaQuestion').innerHTML = '<span class="tool-output-label">現在このツールは工事中です。API 復旧後に再開します。</span>';
        })
        .finally(function () {
          btn.disabled = false;
          btn.textContent = '新しい問題';
        });
    }

    function handleAnswer(e) {
      var btn = e.target;
      if (!btn || !btn.matches('.quiz-option') || !state.correct) return;
      var chosen = btn.getAttribute('data-choice');
      var isCorrect = chosen === state.correct;
      var options = document.querySelectorAll('#triviaChoices .quiz-option');
      Array.prototype.forEach.call(options, function (o) {
        o.disabled = true;
        var oc = o.getAttribute('data-choice') === state.correct;
        o.classList.add(oc ? 'is-correct' : 'is-muted');
        if (o === btn && !isCorrect) o.classList.add('is-incorrect');
      });

      $('triviaExplanation').innerHTML =
        '<span class="tool-output-label">' + (isCorrect ? '正解です！' : '不正解。正解は「' + escapeHtml(state.correct) + '」です。') + '</span>' +
        '<p>問題: ' + escapeHtml(state.question) + '</p>';

      track('trivia_answer', { correct: isCorrect, answer: state.correct });
    }

    function init() {
      $('triviaNewBtn').addEventListener('click', fetchQuestion);
      $('triviaChoices').addEventListener('click', handleAnswer);
      fetchQuestion({ track: false });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
  </script>
</ToolLayout>
