---
import { getCollection, render } from 'astro:content';
import JournalLayout from '../../../layouts/JournalLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('journal', ({ data }) => !data.draft);
  return entries.map((entry) => {
    // entry.id format: "category/slug" (e.g. "devlog/first-post")
    const parts = entry.id.split('/');
    const category = parts[0];
    const slug = parts.slice(1).join('/');
    return {
      params: { category, slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Get raw body text for reading time estimate
const rawContent = entry.body || '';
---
<JournalLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  category={entry.data.category}
  tags={entry.data.tags}
  heroImage={entry.data.heroImage}
  rawContent={rawContent}
  headings={headings}
>
  <Content />
</JournalLayout>
