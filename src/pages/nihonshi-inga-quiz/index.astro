---
import ToolLayout from '../../layouts/ToolLayout.astro';
---
<ToolLayout
  title="日本史 因果クイズ | 飛鳥〜幕末の歴史シナリオ350問・無料"
  description="「もしあなたがこの時代にいたら？」歴史的場面を追体験しながら因果関係を学ぶシナリオ型クイズ。飛鳥〜幕末まで全350問、解説・重要事実付き。"
  canonical="https://www.randaworks.com/nihonshi-inga-quiz/"
  ogImage="https://www.randaworks.com/assets/img/games/inga/demo-cards/combo_nobunaga.jpg"
  pageType="inga_quiz"
  source="inga_quiz"
  tag="飛鳥〜幕末"
  heading="日本史 因果クイズ"
  breadcrumbs={[
    { href: '/history-tools/', label: 'ツール集' },
    { label: '因果クイズ' },
  ]}
  excludeTools={['nihonshi-inga-quiz']}
  gamePitch="このクイズに出てくるシナリオは、ゲーム内で実際にプレイできるイベントです。"
  steamContext="因果クイズのシナリオをカードゲームで追体験"
>
  <div class="tool-workspace">
    <!-- Score bar -->
    <div class="quiz-score-bar" id="scoreBar">
      <div class="score-item"><span class="score-label">正解率</span><span class="score-value" id="scoreRate">—</span></div>
      <div class="score-divider"></div>
      <div class="score-item"><span class="score-label">正解</span><span class="score-value" id="scoreCount">0 / 0</span></div>
      <div class="score-divider"></div>
      <div class="score-item"><span class="score-label">連続正解</span><span class="score-value"><span id="streak">0</span> <span class="streak-fire" id="streakFire" style="display:none;">&#x1F525;</span></span></div>
    </div>

    <!-- Era filter -->
    <div class="era-chips" id="eraChips"></div>

    <!-- Question area -->
    <div id="questionArea">
      <div class="quiz-loading" id="loadingMsg">データを読み込み中</div>
    </div>

    <!-- Choices -->
    <div class="quiz-choices" id="choicesArea" style="display:none;"></div>

    <!-- Hints area (under choices) -->
    <div id="hintsArea" style="display:none;"></div>

    <!-- Feedback -->
    <div id="feedbackArea" style="display:none;"></div>
  </div>
  <script is:inline src="/assets/js/history-tools.js"></script>
  <script is:inline>
  (function() {
    var DATA = null;
    var state = {
      pool: [], current: -1, score: 0, total: 0,
      streak: 0, bestStreak: 0, answered: false, era: 'all'
    };

    function $(id) { return document.getElementById(id); }
    function esc(s) {
      var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML;
    }
    function cardImgUrl(termId) {
      return '/assets/img/cards/' + termId + '.webp';
    }
    function cardImgsHtml(imgs) {
      if (!imgs || !imgs.length) return '';
      return imgs.map(function(tid) {
        return '<img src="' + cardImgUrl(tid) + '" alt="" class="quiz-card-img" loading="lazy">';
      }).join('');
    }
    var ERA_BADGES = {
      asuka_nara: '/assets/img/badges/P02_asuka.jpg',
      heian: '/assets/img/badges/P03_heian.jpg',
      kamakura: '/assets/img/badges/P04_kamakura.jpg',
      muromachi: '/assets/img/badges/P05_muromachi.jpg',
      sengoku: '/assets/img/badges/P06_sengoku.jpg',
      azuchi: '/assets/img/badges/P06_sengoku.jpg',
      edo: '/assets/img/badges/P07_edo.jpg',
      bakumatsu: '/assets/img/badges/P08_bakumatsu.jpg',
    };
    function shuffle(a) {
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = a[i]; a[i] = a[j]; a[j] = t;
      }
      return a;
    }
    function track(ev, payload) {
      if (window.RandaAnalytics && window.RandaAnalytics.track) window.RandaAnalytics.track(ev, payload);
      if (typeof gtag === 'function') gtag('event', ev, payload);
    }

    function tagClass(tag) {
      if (tag === '歴史確定' || tag === '正解') return 'feedback-tag--correct';
      if (tag === '時代錯誤') return 'feedback-tag--anachronism';
      if (tag === '認識齟齬') return 'feedback-tag--confusion';
      if (tag === '暴論') return 'feedback-tag--absurd';
      return 'feedback-tag--wrong';
    }

    function wikiUrl(keyword) {
      return 'https://ja.wikipedia.org/wiki/' + encodeURIComponent(keyword);
    }

    function contactUrl(title) {
      return '/contact/?category=' + encodeURIComponent('不具合報告') + '&source=quiz&message=' + encodeURIComponent('【' + title + '】の内容について\n\n');
    }

    // ── Wikipedia API ──
    var wikiCache = {};
    function fetchWiki(keyword) {
      if (wikiCache[keyword]) return Promise.resolve(wikiCache[keyword]);
      return fetch('https://ja.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(keyword))
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(d) { if (d && d.type !== 'disambiguation') { wikiCache[keyword] = d; return d; } return null; })
        .catch(function() { return null; });
    }

    function renderWikiCard(containerId, keyword) {
      fetchWiki(keyword).then(function(d) {
        if (!d) return;
        var el = $(containerId);
        if (!el) return;
        var thumb = d.thumbnail && d.thumbnail.source ? d.thumbnail.source : '';
        var extract = d.extract ? (d.extract.length > 200 ? d.extract.substring(0, 200) + '…' : d.extract) : '';
        var url = d.content_urls && d.content_urls.desktop ? d.content_urls.desktop.page : wikiUrl(keyword);
        var html = '<div class="wiki-card">';
        if (thumb) html += '<img src="' + esc(thumb) + '" alt="' + esc(d.title) + '" class="wiki-card-thumb" loading="lazy">';
        html += '<div class="wiki-card-body">';
        html += '<h4 class="wiki-card-title">' + esc(d.title) + '</h4>';
        if (extract) html += '<p class="wiki-card-extract">' + esc(extract) + '</p>';
        html += '<a href="' + esc(url) + '" target="_blank" rel="noopener noreferrer" class="wiki-card-link"'
          + ' data-track-event="cta_click" data-track-placement="inga_quiz_wiki_card">&#x1F4D6; Wikipediaで続きを読む</a>';
        html += '</div></div>';
        el.innerHTML = html;
      });
    }

    function buildResourceLinks(keyword) {
      var kw = encodeURIComponent(keyword);
      return '<div class="quiz-resources">'
        + '<a href="' + wikiUrl(keyword) + '" target="_blank" rel="noopener noreferrer" class="quiz-resource" data-track-event="cta_click" data-track-placement="inga_quiz_res_wiki"><span class="quiz-resource-icon">&#x1F4D6;</span> Wikipedia</a>'
        + '<a href="https://ndlsearch.ndl.go.jp/search?keyword=' + kw + '" target="_blank" rel="noopener noreferrer" class="quiz-resource" data-track-event="cta_click" data-track-placement="inga_quiz_res_ndl"><span class="quiz-resource-icon">&#x1F3DB;</span> 国立国会図書館</a>'
        + '<a href="https://cir.nii.ac.jp/all?q=' + kw + '" target="_blank" rel="noopener noreferrer" class="quiz-resource" data-track-event="cta_click" data-track-placement="inga_quiz_res_cinii"><span class="quiz-resource-icon">&#x1F4DA;</span> CiNii</a>'
        + '<a href="/tools/shiryo/?q=' + kw + '" class="quiz-resource" data-track-event="cta_click" data-track-placement="inga_quiz_res_shiryo"><span class="quiz-resource-icon">&#x1F4DC;</span> 古典史料</a>'
        + '</div>';
    }

    var GAME_SCREENSHOTS = [
      '/assets/img/games/inga/ss_01.webp',
      '/assets/img/games/inga/ss_02.webp',
      '/assets/img/games/inga/ss_03.webp',
      '/assets/img/games/inga/ss_04.webp',
      '/assets/img/games/inga/ss_05.webp',
      '/assets/img/games/inga/ss_06.webp',
    ];
    var ssIdx = 0;
    function buildGameCta(source) {
      var img = GAME_SCREENSHOTS[ssIdx % GAME_SCREENSHOTS.length];
      ssIdx++;
      return '<a href="/games/inga/?src=' + source + '" class="quiz-game-cta">'
        + '<img src="' + img + '" alt="日本史因果クロニクル" class="quiz-game-cta-img" loading="lazy">'
        + '<div class="quiz-game-cta-body">'
        + '<div class="quiz-game-cta-label">&#x1F3AE; Game</div>'
        + '<div class="quiz-game-cta-title">このシナリオをゲームでプレイ</div>'
        + '<div class="quiz-game-cta-desc">日本史因果クロニクルでは、このクイズのシナリオが実際のゲームイベントとして登場します。</div>'
        + '</div></a>';
    }

    // ── Data loading ──
    function loadData() {
      fetch('/assets/data/quiz-inga.json')
        .then(function(r) { return r.json(); })
        .then(function(d) {
          DATA = d;
          initEraFilter();
          filterByEra('all');
        })
        .catch(function() {
          $('loadingMsg').textContent = 'データの読み込みに失敗しました。ページを再読み込みしてください。';
        });
    }

    // ── Era filter ──
    function initEraFilter() {
      var container = $('eraChips');
      var total = DATA.items.length;
      var html = '<button class="era-chip is-active" data-era="all" data-era="all">すべて<span class="era-chip-count">(' + total + ')</span></button>';
      DATA.eras.forEach(function(e) {
        html += '<button class="era-chip" data-era="' + e.id + '" data-era="' + e.id + '">'
          + esc(e.name) + '<span class="era-chip-count">(' + e.count + ')</span></button>';
      });
      container.innerHTML = html;
      container.addEventListener('click', function(ev) {
        var btn = ev.target.closest('.era-chip');
        if (!btn) return;
        container.querySelectorAll('.era-chip').forEach(function(c) { c.classList.remove('is-active'); });
        btn.classList.add('is-active');
        filterByEra(btn.getAttribute('data-era'));
      });
    }

    function filterByEra(era) {
      state.era = era;
      state.pool = era === 'all'
        ? DATA.items.slice()
        : DATA.items.filter(function(q) { return q.era === era; });
      shuffle(state.pool);
      state.current = -1;
      state.score = 0;
      state.total = 0;
      state.streak = 0;
      updateScore();
      nextQuestion();
      track('inga_quiz_filter', { era: era, count: state.pool.length });
    }

    // ── Score ──
    function updateScore() {
      var rate = state.total > 0 ? Math.round(state.score / state.total * 100) : 0;
      $('scoreRate').textContent = state.total > 0 ? rate + '%' : '—';
      $('scoreCount').textContent = state.score + ' / ' + state.total;
      $('streak').textContent = state.streak;
      $('streakFire').style.display = state.streak >= 3 ? 'inline' : 'none';
    }

    // ── Question ──
    function nextQuestion() {
      if (!state.pool.length) return;
      state.current = (state.current + 1) % state.pool.length;
      if (state.current === 0 && state.total > 0) shuffle(state.pool);
      state.answered = false;
      renderQuestion();
    }

    function renderQuestion() {
      var q = state.pool[state.current];
      var era = DATA.eras.find(function(e) { return e.id === q.era; });
      var eraName = era ? era.name : q.era;

      // Question card
      var badgeImg = ERA_BADGES[q.era] ? '<img src="' + ERA_BADGES[q.era] + '" alt="" class="era-chip-img">' : '';
      var html = '<div class="quiz-question-card" style="display:flex;gap:16px;align-items:flex-start;">';
      if (q.imgs && q.imgs.length) html += cardImgsHtml(q.imgs.slice(0,1));
      html += '<div style="flex:1;min-width:0;">'
        + '<div class="quiz-q-header">'
        + '<span class="quiz-q-number">Q' + (state.total + 1) + '</span>'
        + '<span class="era-badge" data-era="' + esc(q.era) + '">' + badgeImg + esc(eraName) + '</span>'
        + '</div>'
        + '<h3 class="quiz-q-title">' + esc(q.title) + '</h3>'
        + '<p class="quiz-q-text">' + esc(q.scenario) + '</p>'
        + '</div></div>';
      $('questionArea').innerHTML = html;

      // Choices
      var choicesHtml = '';
      var nums = ['①', '②', '③', '④'];
      q.choices.forEach(function(c, i) {
        choicesHtml += '<button class="quiz-choice" data-idx="' + i + '">'
          + '<span class="choice-num">' + nums[i] + '</span>'
          + '<span>' + esc(c.text) + '</span>'
          + '</button>';
      });
      $('choicesArea').innerHTML = choicesHtml;
      $('choicesArea').style.display = '';

      $('feedbackArea').style.display = 'none';
      $('feedbackArea').innerHTML = '';
      $('hintsArea').style.display = 'none';
      $('hintsArea').innerHTML = '';

      $('questionArea').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ── Answer ──
    function handleAnswer(idx) {
      if (state.answered) return;
      state.answered = true;
      state.total++;

      var q = state.pool[state.current];
      var isCorrect = idx === q.answer;
      if (isCorrect) { state.score++; state.streak++; state.bestStreak = Math.max(state.bestStreak, state.streak); }
      else { state.streak = 0; }
      updateScore();

      // Style choices
      var buttons = $('choicesArea').querySelectorAll('.quiz-choice');
      buttons.forEach(function(btn, i) {
        btn.disabled = true;
        if (i === q.answer) btn.classList.add('is-correct');
        else if (i === idx && !isCorrect) btn.classList.add('is-wrong');
        else btn.classList.add('is-dimmed');
      });

      // Build feedback
      var chosen = q.choices[idx];
      var correct = q.choices[q.answer];
      var html = '<div class="quiz-feedback">';

      // Result tag
      html += '<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">';
      if (isCorrect) {
        html += '<span class="feedback-tag feedback-tag--correct">&#x2713; 正解</span>';
      } else {
        html += '<span class="feedback-tag feedback-tag--wrong">&#x2717; 不正解</span>';
      }
      // Show chosen feedback tag
      if (chosen.tag) {
        html += '<span class="feedback-tag ' + tagClass(chosen.tag) + '">【' + esc(chosen.tag) + '】</span>';
      }
      html += '</div>';

      // Chosen feedback text
      html += '<p class="quiz-feedback-text">' + esc(chosen.feedback.replace(/^【.+?】/, '').trim()) + '</p>';

      // If wrong, show the correct answer's feedback too
      if (!isCorrect) {
        html += '<div style="margin-top:10px;padding:12px 16px;border-radius:10px;background:rgba(74,158,122,0.08);border:1px solid rgba(74,158,122,0.2);">';
        html += '<span class="feedback-tag feedback-tag--correct" style="margin-bottom:8px;">正解: ' + esc(correct.text.substring(0, 50)) + (correct.text.length > 50 ? '…' : '') + '</span>';
        html += '<p style="margin:8px 0 0;font-size:0.88rem;line-height:1.6;color:rgba(255,255,255,0.8);">'
          + esc(correct.feedback.replace(/^【.+?】/, '').trim()) + '</p>';
        html += '</div>';
      }

      // Anchor facts
      if (q.facts && q.facts.length > 0) {
        html += '<ul class="quiz-facts">';
        q.facts.forEach(function(f) {
          html += '<li>' + esc(f) + '</li>';
        });
        html += '</ul>';
      }

      // Remember
      if (q.remember) {
        html += '<div class="quiz-remember">'
          + '<span class="quiz-remember-label">&#x1F4CC; 覚えておきたいポイント</span>'
          + '<p>' + esc(q.remember) + '</p>'
          + '</div>';
      }

      // Wikipedia card placeholder
      var mainKeyword = (q.keywords && q.keywords[0]) || q.title;
      html += '<div id="wikiCardSlot"></div>';

      // Resource links
      html += buildResourceLinks(mainKeyword);

      // Game CTA
      html += buildGameCta('inga_quiz_feedback');

      // Next + Report buttons
      html += '<div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:18px;">';
      html += '<button class="quiz-next-btn" id="nextBtn" style="margin-top:0;">次の問題へ &#x2192;</button>';
      html += '<a href="' + contactUrl(q.title) + '" class="quiz-report-btn">&#x1F6A9; 間違いを報告</a>';
      html += '</div>';
      html += '</div>';

      $('feedbackArea').innerHTML = html;
      $('feedbackArea').style.display = '';

      // Async: fetch Wikipedia thumbnail + summary
      renderWikiCard('wikiCardSlot', mainKeyword);

      $('nextBtn').addEventListener('click', function() { nextQuestion(); });
      $('feedbackArea').scrollIntoView({ behavior: 'smooth', block: 'nearest' });

      track('inga_quiz_answer', {
        placement: 'inga_quiz',
        correct: isCorrect,
        era: q.era,
        title: q.title,
        streak: state.streak
      });
    }

    // ── Events ──
    document.addEventListener('DOMContentLoaded', function() {
      $('choicesArea').addEventListener('click', function(ev) {
        var btn = ev.target.closest('.quiz-choice');
        if (!btn || state.answered) return;
        handleAnswer(parseInt(btn.getAttribute('data-idx'), 10));
      });
      loadData();
    });
  })();
  </script>
</ToolLayout>
