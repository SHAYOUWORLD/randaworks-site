---
import ToolLayout from '../../layouts/ToolLayout.astro';
---
<ToolLayout
  title="【旧版】日本史クイズ ジェネレーター"
  description="飛鳥、平安、鎌倉、室町、戦国、江戸、幕末、明治の人物・出来事クイズをランダム出題。"
  canonical="https://www.randaworks.com/nihonshi-quiz/"
  ogImage="https://www.randaworks.com/assets/img/games/inga/demo-cards/combo_nobunaga.jpg"
  pageType="nihonshi_quiz"
  source="nihonshi_quiz"
  tag="旧版"
  heading="日本史クイズ（旧版）"
  breadcrumbs={[
    { href: '/history-tools/', label: 'ツール集' },
    { label: '日本史クイズ' },
  ]}
  excludeTools={['nihonshi-quiz']}
  gamePitch="このクイズに出てきた人物や出来事が、ゲーム内ではカードとして登場します。"
  steamContext="クイズで扱った時代をカードで再体験"
>
  <meta name="robots" content="noindex, nofollow" slot="head" />
  <div class="tool-workspace">
    <div style="padding:14px 18px;border-radius:10px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.2);margin-bottom:18px;font-size:0.88rem;color:rgba(255,255,255,0.7);">
      このページは旧版です。新しいクイズは <a href="/nihonshi-inga-quiz/" style="color:#f59e0b;font-weight:600;">日本史 因果クイズ</a>、<a href="/nihonshi-ichimon-ittou/" style="color:#f59e0b;font-weight:600;">一問一答</a>、<a href="/nihonshi-inga-chain/" style="color:#f59e0b;font-weight:600;">因果チェーン</a> をご利用ください。
    </div>
    <div class="tool-input-row" style="justify-content: space-between;">
      <label for="historyQuizPeriod" style="min-width:0;">出題範囲
        <select id="historyQuizPeriod">
          <option value="all">すべて</option>
          <option value="ancient">飛鳥</option>
          <option value="heian">平安</option>
          <option value="kamakura">鎌倉</option>
          <option value="muromachi">室町</option>
          <option value="sengoku">戦国</option>
          <option value="edo">江戸</option>
          <option value="bakumatsu">幕末</option>
          <option value="meiji">明治</option>
        </select>
      </label>
      <button class="tool-btn" id="historyQuizGenerate" type="button">出題</button>
    </div>
    <div class="tool-output" id="historyQuizQuestion"></div>
    <div class="quiz-option-grid" id="historyQuizChoices"></div>
    <div class="tool-output" id="historyQuizExplanation" style="margin-top:12px;"></div>
  </div>
  <script is:inline src="/assets/js/history-tools.js"></script>
</ToolLayout>
