---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RelatedTools from '../components/RelatedTools.astro';
import SteamWidget from '../components/SteamWidget.astro';

interface BreadcrumbItem {
  href?: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  pageType: string;
  source: string;
  tag?: string;
  heading: string;
  desc?: string;
  breadcrumbs: BreadcrumbItem[];
  excludeTools?: string[];
  navLinks?: { href: string; label: string }[];
  gamePitch?: string;
  steamContext?: string;
  enHref?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  pageType,
  source,
  tag,
  heading,
  desc,
  breadcrumbs,
  excludeTools = [],
  navLinks,
  gamePitch,
  steamContext,
  enHref,
} = Astro.props;
---
<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} pageType={pageType}>
  <link rel="stylesheet" href="/assets/css/history-tools.css" slot="head" />
  <slot name="head" slot="head" />
  <div class="container tool-page">
    <Nav links={navLinks} enHref={enHref} />

    <main id="main-content">
      <Breadcrumb items={breadcrumbs} />

      <div class="tool-page-header">
        <h1>{heading}</h1>
        {tag && <span class="tool-page-tag">{tag}</span>}
      </div>
      {desc && <p class="tool-page-desc">{desc}</p>}

      <slot />

      <div class="tool-footer-section">
        <RelatedTools source={source} exclude={excludeTools} gamePitch={gamePitch} />
        <SteamWidget source={source} context={steamContext} />
      </div>
    </main>

    <Footer source={source} />
  </div>

  <style is:inline>
    .tool-rich-section {
      display: grid;
      gap: 14px;
      margin-top: 20px;
    }

    .tool-rich-section h2 {
      margin: 0;
      color: #fff;
      font-size: 1.08rem;
    }

    .tool-rich-section p,
    .tool-rich-section li {
      margin: 0;
      color: var(--text-muted);
      line-height: 1.75;
      font-size: 0.92rem;
    }

    .tool-rich-list {
      display: grid;
      gap: 10px;
      padding-left: 1.2rem;
      margin: 0;
    }

    .tool-rich-grid {
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tool-faq-list {
      display: grid;
      gap: 12px;
    }

    .tool-faq-item {
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.02);
      padding: 14px 16px;
    }

    .tool-faq-item summary {
      cursor: pointer;
      color: #fff;
      font-weight: 700;
      list-style: none;
    }

    .tool-faq-item summary::-webkit-details-marker {
      display: none;
    }

    .tool-faq-item p {
      margin-top: 10px;
    }

    @media (max-width: 720px) {
      .tool-rich-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
