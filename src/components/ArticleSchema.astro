---
interface Props {
  title: string;
  description: string;
  url: string;
  image?: string;
  datePublished: string;
  dateModified?: string;
  category: string;
  categoryUrl: string;
}

const {
  title,
  description,
  url,
  image,
  datePublished,
  dateModified,
  category,
  categoryUrl,
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      headline: title,
      description,
      url,
      ...(image && { image: { "@type": "ImageObject", url: image } }),
      datePublished,
      ...(dateModified && { dateModified }),
      inLanguage: "ja",
      author: {
        "@type": "Organization",
        name: "RandaWorks",
        url: "https://www.randaworks.com/",
      },
      publisher: {
        "@type": "Organization",
        name: "RandaWorks",
        url: "https://www.randaworks.com/",
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "ホーム", item: "https://www.randaworks.com/" },
        { "@type": "ListItem", position: 2, name: "制作ノート", item: "https://www.randaworks.com/journal/" },
        { "@type": "ListItem", position: 3, name: category, item: categoryUrl },
        { "@type": "ListItem", position: 4, name: title },
      ],
    },
  ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
