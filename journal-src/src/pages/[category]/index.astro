---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = ['devlog', 'game-design', 'ai', 'game-study', 'research'];
  return categories.map((cat) => ({ params: { category: cat } }));
}

const CATEGORY_NAMES: Record<string, string> = {
  devlog:       '開発ログ',
  'game-design': 'ゲーム設計',
  ai:           'AI活用メモ',
  'game-study': 'ゲーム研究・レビュー',
  research:     'リサーチノート',
};

const CATEGORY_DESC: Record<string, string> = {
  devlog:       '何を作り、どう動かし、何に詰まったか。制作の過程と解決の記録。',
  'game-design': 'メカニクス、レベルデザイン、体験設計の考察。なぜそう設計したか、試してみてどうだったか。',
  ai:           '開発でAIをどう使うか。効いた使い方、落とし穴——ツールではなく実践単位の記録。',
  'game-study': '本気でプレイして得た知見と分析。メカニクスを読み解き、設計を学ぶ記録。',
  research:     '制作に関連するテーマの調査と考察。歴史、認知、学習、設計論など。',
};

const { category } = Astro.params;
const categoryName = CATEGORY_NAMES[category] ?? category;
const categoryDesc = CATEGORY_DESC[category] ?? '';

const allEntries = await getCollection('journal', ({ data, id }) => {
  return !data.draft && id.startsWith(`${category}/`);
});
allEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": `${categoryName} | 制作ノート | RandaWorks`,
      "url": `https://www.randaworks.com/journal/${category}/`,
      "inLanguage": "ja"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://www.randaworks.com/" },
        { "@type": "ListItem", "position": 2, "name": "制作ノート", "item": "https://www.randaworks.com/journal/" },
        { "@type": "ListItem", "position": 3, "name": categoryName }
      ]
    }
  ]
};
---
<BaseLayout
  title={`${categoryName} | 制作ノート | RandaWorks`}
  description={`RandaWorksの${categoryName}です。${categoryDesc}`}
  canonicalPath={`/journal/${category}/`}
  bodyClass="journal-page"
  ldJson={ldJson}
>
  <ul class="breadcrumb">
    <li><a href="/">ホーム</a></li>
    <li class="breadcrumb-separator" aria-hidden="true">›</li>
    <li><a href="/journal/">制作ノート</a></li>
    <li class="breadcrumb-separator" aria-hidden="true">›</li>
    <li class="breadcrumb-current" aria-current="page">{categoryName}</li>
  </ul>

  <div class="journal-shell">
    <header class="journal-page-header">
      <p class="section-kicker">制作ノート / カテゴリ</p>
      <h1>{categoryName}</h1>
      <p class="journal-page-lead">{categoryDesc}</p>
    </header>

    {allEntries.length === 0 ? (
      <section class="journal-section-panel">
        <div class="journal-panel-heading">
          <p class="section-kicker">このカテゴリについて</p>
          <h2>{categoryName}の記録を始める</h2>
        </div>
        <p>まだ記事がありません。近日公開予定です。</p>
        <p><a class="journal-entry-link" href="/journal/">制作ノートトップへ戻る</a></p>
      </section>
    ) : (
      <section class="journal-section-panel">
        <div class="journal-panel-heading">
          <p class="section-kicker">一覧</p>
          <h2>{categoryName}の記事</h2>
        </div>
        <div class="journal-entry-list">
          {allEntries.map((entry) => {
            const [cat, ...slugParts] = entry.id.split('/');
            const slug = slugParts.join('/').replace(/\.(md|mdx)$/, '');
            return (
              <article class="journal-entry-card">
                <p class="journal-entry-meta">{categoryName} ・ {entry.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long' })}</p>
                <h2 class="journal-entry-title"><a href={`/journal/${cat}/${slug}/`}>{entry.data.title}</a></h2>
                <p>{entry.data.description}</p>
                {entry.data.tags.length > 0 && (
                  <div class="badges">
                    {entry.data.tags.map((tag) => <span class="badge">{tag}</span>)}
                  </div>
                )}
                <a class="journal-entry-link" href={`/journal/${cat}/${slug}/`}>記事を読む</a>
              </article>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
